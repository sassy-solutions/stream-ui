{
  "name": "@stream-ui/testing",
  "version": "1.0.0",
  "description": "Mocks, AG-UI fixtures, RTL helpers for testing @stream-ui consumers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@stream-ui/core": "workspace:*",
    "@stream-ui/protocol": "workspace:*"
  },
  "peerDependencies": {
    "@stream-ui/react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@stream-ui/react": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@vitest/coverage-v8": "^2.1.8",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "size-limit": [
    {
      "name": "@stream-ui/testing (ESM)",
      "path": "dist/index.js",
      "limit": "6 KB",
      "gzip": true,
      "ignore": [
        "@stream-ui/core",
        "@stream-ui/protocol",
        "@stream-ui/react",
        "@testing-library/react",
        "react",
        "react-dom",
        "vitest"
      ]
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sassy-solutions/stream-ui.git",
    "directory": "packages/testing"
  }
}
