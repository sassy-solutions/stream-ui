{
  "name": "@stream-ui/core",
  "version": "0.0.0",
  "description": "Transport (SSE/WS), incremental JSON parser, state store, form engine. Pure TS, zero deps.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/zod": {
      "types": "./dist/adapters/zod.d.ts",
      "import": "./dist/adapters/zod.js",
      "require": "./dist/adapters/zod.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@stream-ui/protocol": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@vitest/coverage-v8": "^2.1.8",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.23.0"
  },
  "size-limit": [
    {
      "name": "@stream-ui/core (ESM, no zod)",
      "path": "dist/index.js",
      "limit": "15 KB",
      "gzip": true,
      "ignore": ["zod", "@stream-ui/protocol"]
    },
    {
      "name": "@stream-ui/core/adapters/zod (ESM)",
      "path": "dist/adapters/zod.js",
      "limit": "3 KB",
      "gzip": true,
      "ignore": ["zod", "@stream-ui/protocol", "@stream-ui/core"]
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sassy-solutions/stream-ui.git",
    "directory": "packages/core"
  }
}
