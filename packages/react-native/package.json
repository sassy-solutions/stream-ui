{
  "name": "@stream-ui/react-native",
  "version": "0.0.0",
  "description": "React Native hooks + native primitives (TextInput, FlatList) for @stream-ui.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@stream-ui/core": "workspace:*",
    "@stream-ui/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "react": "^19.0.0",
    "react-native": "0.76.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sassy-solutions/stream-ui.git",
    "directory": "packages/react-native"
  }
}
