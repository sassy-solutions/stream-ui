{
  "name": "@stream-ui/react-native",
  "version": "0.0.0",
  "description": "React Native hooks + native primitives (TextInput, FlatList) for @stream-ui.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@stream-ui/core": "workspace:*",
    "@stream-ui/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-native": "0.76.5",
    "react-test-renderer": "19.0.0",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "size-limit": [
    {
      "name": "@stream-ui/react-native (ESM, primitives only)",
      "path": "dist/index.js",
      "limit": "8 KB",
      "gzip": true,
      "ignore": [
        "react",
        "react-native",
        "@stream-ui/core",
        "@stream-ui/core/shared-react",
        "@stream-ui/protocol"
      ]
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sassy-solutions/stream-ui.git",
    "directory": "packages/react-native"
  }
}
