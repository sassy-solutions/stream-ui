    "@stream-ui/testing": "workspace:*",
    "expo": "~53.0.0",
    "expo-constants": "~17.1.0",
    "expo-linking": "~7.1.0",
    "expo-router": "~5.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "typescript": "^5.7.2"
  }
}
