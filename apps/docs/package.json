{
  "name": "docs",
  "version": "0.0.1",
  "private": true,
  "description": "@stream-ui documentation site (Nextra v3 on Next.js 15).",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run gen:api && next build",
    "start": "next start",
    "gen:api": "typedoc --options typedoc.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .turbo pages/reference/generated"
  },
  "dependencies": {
    "next": "^15.1.3",
    "nextra": "^3.2.5",
    "nextra-theme-docs": "^3.2.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@stream-ui/protocol": "workspace:*",
    "@stream-ui/core": "workspace:*",
    "@stream-ui/react": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "typedoc": "~0.27.9",
    "typedoc-plugin-markdown": "~4.4.2",
    "typescript": "^5.7.2"
  }
}
